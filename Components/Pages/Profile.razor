@page "/profile"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Identity
@using System.Security.Claims
@using Snackis.Domain.Entities

@inject AuthenticationStateProvider AuthStateProvider
@inject UserManager<MyUser> UserManager

<h3>Profil</h3>

@if (user == null)
{
    <p>Du måste vara inloggad!</p>
}
else
{
    <div class="mb-3">
        <label>Username</label>
        <InputText class="form-control" @bind-Value="username" />
    </div>

    <div class="mb-3">
        <label>Profilbild</label>
        <InputFile OnChange="UploadImage" />
    </div>

    @if (!string.IsNullOrEmpty(image))
    {
        <img src="@image" width="120" style="border-radius:10px;" />
    }

    <br />
    <br />

    <button class="btn btn-primary" @onclick="Save">Spara</button>
}
@code{
    private MyUser? user;
    private string? username;
    private string? image;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var principal = authState.User;

        var userId = principal.FindFirstValue(ClaimTypes.NameIdentifier);

        if (userId == null)
            return;

        user = await UserManager.FindByIdAsync(userId);

        if (user == null)
            return;

        username = user.UserName;
        image = user.Image;
    }

    private async Task UploadImage(InputFileChangeEventArgs e)
    {
        var file = e.File;

        var fileName = $"{Guid.NewGuid()}_{file.Name}";
        var path = Path.Combine("wwwroot/uploads", fileName);

        Directory.CreateDirectory("wwwroot/uploads");

        await using var stream = File.Create(path);
        await file.OpenReadStream(5 * 1024 * 1024).CopyToAsync(stream);

        image = $"/uploads/{fileName}";
    }

    private async Task Save()
    {
        Console.WriteLine("SAVE CLICKED");

        if (user == null)
            return;

        // username update 
        if (!string.IsNullOrWhiteSpace(username))
        {
            await UserManager.SetUserNameAsync(user, username);
        }

        // profilbild
        user.Image = image;

        var result = await UserManager.UpdateAsync(user);

        if (!result.Succeeded)
        {
            foreach (var error in result.Errors)
            {
                Console.WriteLine(error.Description);
            }
            return;
        }

        // reload user
        user = await UserManager.FindByIdAsync(user.Id);

        username = user.UserName;
        image = user.Image;

        StateHasChanged();
    }

}